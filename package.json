{
  "name": "latency-ladder",
  "version": "0.1.0",
  "private": true,
  "description": "Live, in-browser micro-benchmarks of cache, RAM, IndexedDB, and network latency, animated on one logarithmic scale.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && tsc -p tsconfig.json --noEmit && vite build",
    "build:wasm": "asc assembly/index.ts --target release --outFile src/wasm/kernel.wasm --bindings esm",
    "preview": "vite preview",
    "pretest": "npm run build:wasm",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "assemblyscript": "^0.27.29",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
